{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./ts",
    "skipLibCheck": true
  },
  "include": ["ts/**/*.ts"],
  "exclude": ["node_modules", "dist", "pkg", "example"]
}
