{
  "name": "enx-wasm-parser",
  "version": "0.1.0",
  "description": "Parse Teledyne RDI PD0/ENX acoustic data files via Rust/WebAssembly, off the main thread",
  "author": "Amir Azimi <amir.az@unb.ca>",
  "license": "MIT",
  "keywords": [
    "wasm",
    "webassembly",
    "parser",
    "adcp",
    "teledyne",
    "rdi",
    "pd0",
    "enx",
    "acoustic",
    "oceanography",
    "doppler",
    "rust"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:wasm": "wasm-pack build --target bundler --out-dir pkg && node -e \"require('fs').writeFileSync('pkg/.npmignore','')\"",
    "build:ts": "tsc --project tsconfig.json",
    "build": "npm run build:wasm && npm run build:ts",
    "dev": "vite example",
    "preview": "vite preview example"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-wasm": "^3.3.0",
    "vite-plugin-top-level-await": "^1.4.0"
  }
}
